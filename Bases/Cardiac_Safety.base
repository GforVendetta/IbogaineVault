filters:
  and:
    - file.ext == "md"
    - category == "RED"
properties:
  file.name:
    displayName: Paper
  year:
    displayName: Year
  clinical_significance:
    displayName: Significance
  key_findings:
    displayName: Key Findings
views:
  - type: table
    name: Cardiac Safety Evidence
    order:
      - file.name
      - year
      - clinical_significance
      - key_findings
    sort: []
    columnSize:
      note.clinical_significance: 156
